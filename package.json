{
  "name": "cookbook",
  "version": "1.0.0",
  "description": "A simple cookbook application",
  "scripts": {
    "prepare": "husky || true",
    "check-updates": "ncu -i -w",
    "browserslist-update": "npx update-browserslist-db@latest",
    "build": "npm run -w frontend build",
    "start": "npm run -w backend start"
  },
  "author": "lpgera",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": "^26.0.0",
    "npm": ">11.0.0"
  },
  "volta": {
    "node": "26.4.0"
  },
  "workspaces": [
    "backend",
    "frontend"
  ],
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "npm-check-updates": "^22.2.9",
    "prettier": "^3.8.4"
  },
  "lint-staged": {
    "*.{ts,js,css,md,json,yml}": "prettier --write"
  },
  "allowScripts": {
    "@apollo/protobufjs@1.2.7": true,
    "fsevents@2.3.3": true
  }
}
